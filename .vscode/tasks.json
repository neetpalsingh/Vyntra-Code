{
  "version": "2.0.0",
  "tasks": [
    {
      "type": "npm",
      "script": "watch:extension",
      "problemMatcher": "$tsc-watch",
      "isBackground": true,
      "presentation": {
        "reveal": "never"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "Build Extension",
      "type": "npm",
      "script": "build:extension",
      "problemMatcher": "$tsc"
    },
    {
      "label": "Build All",
      "type": "npm",
      "script": "build:all",
      "problemMatcher": "$tsc"
    }
  ]
}
